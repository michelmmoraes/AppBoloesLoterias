@page "/gerenciar-concurso"
@page "/gerenciar-concurso/{IdParam}"
@using AppBoloesLoterias
@inject Supabase.Client Supabase
@inject NavigationManager Nav

<PageTitle>@(EhEdicao ? "Editar Concurso" : "Novo Concurso")</PageTitle>

<div style="padding: 20px; max-width: 600px; margin: auto; font-family: sans-serif;">
    <h2 style="color: #333;">🎰 @(EhEdicao ? "Editar" : "Novo") Concurso</h2>
    <hr style="border: 0; border-top: 1px solid #eee; margin-bottom: 20px;" />

    @if (carregando)
    {
        <p><em>⏳ Carregando dados...</em></p>
    }
    else
    {
        <div style="display: flex; gap: 15px; margin-bottom: 15px;">
            <div style="flex: 2;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Tipo de Loteria:</label>
                <select @bind="TipoSelecionado" class="form-control" style="width: 100%; padding: 10px; border-radius: 5px; border: 1px solid #ccc;">
                    <option value="">-- Selecione --</option>
                    <option value="Mega-Sena">Mega-Sena</option>
                    <option value="Lotofácil">Lotofácil</option>
                </select>
            </div>
            
            <div style="flex: 1;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Número:</label>
                <input @bind="concurso.Numero" type="number" class="form-control" style="width: 100%; padding: 10px; border-radius: 5px; border: 1px solid #ccc;" />
            </div>
        </div>

        <div style="margin-bottom: 25px;">
            <label style="display: block; font-weight: bold; margin-bottom: 5px;">Data do Sorteio:</label>
            <input @bind="concurso.DataSorteio" type="date" class="form-control" style="width: 100%; padding: 10px; border-radius: 5px; border: 1px solid #ccc;" />
        </div>

        @if (maxDezenas > 0)
        {
            <div style="background-color: #f8f9fa; padding: 15px; border-radius: 8px; border: 1px solid #e9ecef; margin-bottom: 20px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <h4 style="margin: 0; color: #007bff;">🎯 Resultado Oficial</h4>
                    
                    <span style="background-color: @(dezenasSelecionadas.Count == qtdExigida ? "#d4edda" : "#e9ecef"); color: @(dezenasSelecionadas.Count == qtdExigida ? "#155724" : "#495057"); padding: 5px 10px; border-radius: 20px; font-weight: bold; font-size: 14px; border: 1px solid @(dezenasSelecionadas.Count == qtdExigida ? "#c3e6cb" : "#ccc");">
                        Selecionadas: @dezenasSelecionadas.Count / @qtdExigida
                    </span>
                </div>
                
                <p style="font-size: 13px; color: #666; margin-bottom: 10px;">Clique nas dezenas para registrar o resultado do sorteio:</p>
                
                <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                    @for (int i = 1; i <= maxDezenas; i++)
                    {
                        var dezena = i;
                        var selecionado = dezenasSelecionadas.Contains(dezena);
                        <button type="button"
                                @onclick="() => ToggleDezena(dezena)"
                                style="width: 45px; height: 45px; border-radius: 50%; font-weight: bold; font-size: 16px; border: 2px solid @(selecionado ? "#28a745" : "#ccc"); background-color: @(selecionado ? "#28a745" : "white"); color: @(selecionado ? "white" : "#333"); cursor: pointer; transition: 0.2s;">
                            @dezena.ToString("D2")
                        </button>
                    }
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(mensagem))
        {
            <div style="padding: 15px; margin-bottom: 20px; border-radius: 8px; background-color: @(mensagem.Contains("✅") ? "#d4edda" : "#f8d7da"); color: @(mensagem.Contains("✅") ? "#155724" : "#721c24"); border: 1px solid @(mensagem.Contains("✅") ? "#c3e6cb" : "#f5c6cb");">
                @mensagem
            </div>
        }

        <button @onclick="Salvar" disabled="@processando"
                style="width: 100%; padding: 15px; font-size: 18px; font-weight: bold; background-color: @(processando ? "#ccc" : "#007bff"); color: white; border: none; border-radius: 8px; cursor: pointer;">
            @(processando ? "⏳ SALVANDO..." : "💾 SALVAR CONCURSO")
        </button>
    }
</div>

@code {
    [Parameter]
    public string IdParam { get; set; }

    private Concurso concurso = new Concurso { DataSorteio = DateTime.Today };
    private bool carregando = false;
    private bool processando = false;
    private string mensagem;

    private List<int> dezenasSelecionadas = new List<int>();
    private int maxDezenas = 0;
    private int qtdExigida = 0; // Nova variável para controlar o limite

    private bool EhEdicao => !string.IsNullOrEmpty(IdParam);

    private string TipoSelecionado
    {
        get => concurso.Tipo;
        set
        {
            concurso.Tipo = value;
            ConfigurarMatrizes();
            dezenasSelecionadas.Clear();
            mensagem = ""; // Limpa os erros ao trocar de loteria
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (EhEdicao)
        {
            carregando = true;
            try
            {
                var response = await Supabase.From<Concurso>().Get();
                var encontrado = response.Models.FirstOrDefault(c => c.Id.ToString() == IdParam);
                if (encontrado != null)
                {
                    concurso = encontrado;
                    dezenasSelecionadas = concurso.ResultadoDezenas?.ToList() ?? new List<int>();
                    ConfigurarMatrizes();
                }
                else
                {
                    mensagem = "❌ Concurso não encontrado.";
                }
            }
            catch (Exception ex)
            {
                mensagem = "Erro ao carregar: " + ex.Message;
            }
            finally
            {
                carregando = false;
            }
        }
    }

    private void ConfigurarMatrizes()
    {
        switch (concurso.Tipo)
        {
            case "Mega-Sena":
                maxDezenas = 60;
                qtdExigida = 6;
                break;
            case "Lotofácil":
                maxDezenas = 25;
                qtdExigida = 15;
                break;
            default:
                maxDezenas = 0;
                qtdExigida = 0;
                break;
        }
    }

    private void ToggleDezena(int numero)
    {
        // Se a mensagem for de limite atingido, limpa ela quando o usuário clicar de novo
        if (mensagem != null && mensagem.Contains("já marcou")) mensagem = "";

        if (dezenasSelecionadas.Contains(numero))
        {
            dezenasSelecionadas.Remove(numero);
        }
        else
        {
            // TRAVA VISUAL: Impede de clicar em mais bolinhas do que o jogo permite
            if (dezenasSelecionadas.Count >= qtdExigida)
            {
                mensagem = $"⚠️ Você já marcou as {qtdExigida} dezenas permitidas para a {concurso.Tipo}!";
                return;
            }
            
            dezenasSelecionadas.Add(numero);
            dezenasSelecionadas.Sort();
        }
    }

    private async Task Salvar()
    {
        if (string.IsNullOrWhiteSpace(concurso.Tipo))
        {
            mensagem = "⚠️ Selecione o tipo de loteria.";
            return;
        }

        if (concurso.Numero <= 0)
        {
            mensagem = "⚠️ Digite um número de concurso válido.";
            return;
        }

        // TRAVA DE SALVAMENTO: Permite vazio (0) para agendar o sorteio.
        // Mas se marcou alguma coisa, tem que ser a quantidade exata!
        if (dezenasSelecionadas.Any() && dezenasSelecionadas.Count != qtdExigida)
        {
            mensagem = $"⚠️ Para lançar o resultado oficial, você precisa marcar exatamente {qtdExigida} dezenas (você marcou {dezenasSelecionadas.Count}).";
            return;
        }

        try
        {
            processando = true;
            mensagem = "⏳ Salvando...";

            concurso.ResultadoDezenas = dezenasSelecionadas.Any() ? dezenasSelecionadas.ToArray() : null;
            concurso.ResultadoSecundario = null;

            if (EhEdicao)
            {
                await Supabase.From<Concurso>().Update(concurso);
            }
            else
            {
                concurso.CriadoEm = DateTime.Now;
                await Supabase.From<Concurso>().Insert(concurso);
            }

            mensagem = $"✅ Concurso {concurso.Numero} salvo com sucesso!";
            
            if (!EhEdicao)
            {
                concurso = new Concurso { DataSorteio = DateTime.Today, Tipo = concurso.Tipo };
                dezenasSelecionadas.Clear();
            }
        }
        catch (Exception ex)
        {
            mensagem = "❌ Erro ao salvar: " + ex.Message;
        }
        finally
        {
            processando = false;
        }
    }
}