@page "/lista-boloes"
@using AppBoloesLoterias
@inject Supabase.Client Supabase
@inject NavigationManager Nav

<PageTitle>Meus Bolões</PageTitle>

<div style="padding: 20px; max-width: 800px; margin: auto; font-family: sans-serif;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 style="margin: 0; color: #333;">🎟️ Meus Bolões</h2>
        <button @onclick='() => Nav.NavigateTo("gerenciar-bolao")'
                style="padding: 10px 15px; background-color: #28a745; color: white; border: none; border-radius: 5px; cursor: pointer; font-weight: bold;">
            ➕ Novo Bolão
        </button>
    </div>

    @if (carregando)
    {
        <p><em>⏳ Carregando os bolões do banco de dados...</em></p>
    }
    else if (!boloes.Any())
    {
        <div class="alert alert-info">Nenhum bolão cadastrado ainda. Bora criar o primeiro!</div>
    }
    else
    {
        @foreach (var bolao in boloes)
        {
            var concurso = concursos.FirstOrDefault(c => c.Id == bolao.ConcursoId);
            var nomeConcurso = concurso != null ? $"{concurso.Tipo} - Concurso {concurso.Numero}" : "Concurso não encontrado";
            var dataSorteio = concurso?.DataSorteio?.ToString("dd/MM/yyyy") ?? "Sem data";

            // Define a cor da borda baseado no status atualizado
            string corStatus = bolao.Status switch
            {
                "ABERTO" => "#28a745",   // Verde
                "FECHADO" => "#ffc107",  // Amarelo
                "APURADO" => "#007bff",  // Azul
                _ => "#dc3545"           // Vermelho (Cancelado)
            };

            <div style="background: white; border: 1px solid #ddd; border-left: 5px solid @corStatus; border-radius: 8px; padding: 15px; margin-bottom: 15px; box-shadow: 2px 2px 5px rgba(0,0,0,0.05);">
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                    
                    <div style="flex: 1;">
                        <strong style="font-size: 18px; color: #007bff;">@nomeConcurso</strong>
                        
                        <div style="display: flex; gap: 15px; margin-top: 8px; font-size: 14px; color: #555;">
                            <span>📅 Sorteio: @dataSorteio</span>
                            <span>💰 Cota: R$ @bolao.ValorCota.ToString("N2")</span>
                            <span>🏦 Fundo: @bolao.PercentualFundo%</span>
                        </div>

                        <div style="margin-top: 10px;">
                            <span style="background-color: @corStatus; color: @(bolao.Status == "FECHADO" ? "#333" : "white"); padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold;">
                                @bolao.Status
                            </span>
                            
                            @if (bolao.Status == "APURADO" && bolao.PremioTotal > 0)
                            {
                                <span style="margin-left: 10px; color: #28a745; font-weight: bold;">
                                    🏆 Prêmio: R$ @bolao.PremioTotal.ToString("N2")
                                </span>
                            }
                            @if (bolao.Status == "APURADO" && bolao.PremioTotal <= 0)
                            {
                                <span style="margin-left: 10px; color: #dc3545; font-weight: bold;">
                                    🗑️ Sem prêmio
                                </span>
                            }
                        </div>
                    </div>
                    
                    <div style="display: flex; flex-direction: column; gap: 10px;">
                        <button @onclick='() => Nav.NavigateTo($"cotas-bolao/{bolao.Id}")'
                                style="background: #28a745; color: white; border: none; border-radius: 8px; padding: 8px; cursor: pointer; font-weight: bold; transition: 0.2s;" title="Gerenciar Cotas">
                            💰 Cotas
                        </button>
                        <button @onclick='() => Nav.NavigateTo($"gerenciar-bolao/{bolao.Id}")'
                                style="background: #f8f9fa; border: 1px solid #ccc; border-radius: 8px; padding: 8px; cursor: pointer; transition: 0.2s;" title="Editar Bolão">
                            ✏️ Editar
                        </button>
                    </div>

                </div>
            </div>
        }
    }

    <button @onclick='() => Nav.NavigateTo("")'
            style="width: 100%; margin-top: 20px; background: #eee; border: 1px solid #ccc; padding: 12px; border-radius: 8px; cursor: pointer;">
        ⬅ Voltar para Home
    </button>
</div>

@code {
    private List<Bolao> boloes = new List<Bolao>();
    private List<Concurso> concursos = new List<Concurso>();
    private bool carregando = true;

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        try
        {
            var responseConcursos = await Supabase.From<Concurso>().Get();
            concursos = responseConcursos.Models;

            var responseBoloes = await Supabase.From<Bolao>().Get();
            boloes = responseBoloes.Models.OrderByDescending(b => b.Id).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Erro ao carregar: " + ex.Message);
        }
        finally
        {
            carregando = false;
        }
    }
}